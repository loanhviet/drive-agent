# Application
APP_ENV=development
APP_DB_PATH=.data/drive_agent.db
JWT_SECRET=
JWT_EXPIRE_MINUTES=60
APP_ACCESS_TOKEN=

# LLM: gemini or anthropic
LLM_PROVIDER=gemini
LLM_MODEL=
LLM_TEMPERATURE=0
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MAX_AGENT_TURNS=8
AGENT_CONTEXT_MAX_CHARS=30000

# Embeddings: gemini or openai
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=16
OPENAI_API_KEY=

# Qdrant: local or server
QDRANT_MODE=local
QDRANT_PATH=.data/qdrant
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_HOST=localhost
QDRANT_PORT=6333
MEMORY_COLLECTION=agent_memory

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MEMORY_SCORE_THRESHOLD=0.3
FILE_PREVIEW_CHARS=6000

# Google Drive
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_FOLDER_ID=
